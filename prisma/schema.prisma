// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CONSULTA
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum CatalogStatus {
  ACTIVE
  INACTIVE
  HIDDEN
}

enum FolderStatus {
  ACTIVE
  INACTIVE
}

enum ColumnDataType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  DATETIME
  IMAGE
  FORMULA
  UNKNOWN
}

enum UploadedFileStatus {
  STORED
  PROCESSING
  PROCESSED
  FAILED
}

enum ImportJobStatus {
  STORED
  ANALYZING
  PENDING_DESTINATION
  PENDING_CONFIG
  PROCESSING
  READY_TO_APPLY
  PUBLISHED
  FAILED
  CANCELLED
}

enum ImportActionType {
  IMPORTAR_LISTA
  COMBINAR_LISTA
  REEMPLAZAR_LISTA
}

enum ImportSheetClassification {
  IMPORTABLE
  INDEX
  AUXILIARY
  IGNORED
}

/// Perfil local sincronizado con Supabase Auth (`auth.users.id` → `User.id`).
model User {
  id           String     @id @db.Uuid
  name         String
  email        String     @unique
  role         UserRole   @default(CONSULTA)
  status       UserStatus @default(ACTIVE)
  lastAccessAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  auditLogs    AuditLog[]
  uploadedFiles UploadedFile[]

  @@index([status])
}

/// Catálogo visible en el directorio privado.
model Catalog {
  id                  String        @id @default(cuid())
  name                String
  description         String?
  coverImagePath      String?
  status              CatalogStatus @default(ACTIVE)
  order               Int           @default(0)
  visibleToNormalUser Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  folders     CatalogFolder[]
  importJobs  ImportJob[]

  @@index([status])
  @@index([order])
  @@index([status, visibleToNormalUser])
}

/// Carpeta dentro de un catálogo (generalmente una hoja Excel).
model CatalogFolder {
  id                  String       @id @default(cuid())
  catalogId           String
  name                String
  description         String?
  status              FolderStatus @default(ACTIVE)
  order               Int          @default(0)
  visibleToNormalUser Boolean      @default(true)
  searchConfig        Json?
  filterConfig        Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  catalog    Catalog        @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  columns    FolderColumn[]
  products   Product[]
  importJobs ImportJob[]

  @@unique([catalogId, name])
  @@index([catalogId])
  @@index([catalogId, order])
  @@index([status])
  @@index([visibleToNormalUser])
}

/// Columna configurada dentro de una carpeta.
model FolderColumn {
  id                    String         @id @default(cuid())
  folderId              String
  originalName          String
  displayName           String
  internalKey           String
  dataType              ColumnDataType @default(UNKNOWN)
  order                 Int            @default(0)
  visibleToNormalUser   Boolean        @default(true)
  isSearchable          Boolean        @default(false)
  isGloballySearchable  Boolean        @default(false)
  isFilterable          Boolean        @default(false)
  isGloballyFilterable  Boolean        @default(false)
  isAdminEditable       Boolean        @default(true)
  isPrimaryCode         Boolean        @default(false)
  isEquivalence         Boolean        @default(false)
  isDescription         Boolean        @default(false)
  isImageCode           Boolean        @default(false)
  isRequired            Boolean        @default(false)
  isReadOnly            Boolean        @default(false)
  width                 Int?
  format                String?
  unit                  String?
  label                 String?
  globalFieldKey        String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  folder CatalogFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([folderId, internalKey])
  @@index([folderId])
  @@index([folderId, order])
}

/// Producto (fila de datos) dentro de una carpeta.
model Product {
  id               String   @id @default(cuid())
  folderId         String
  primaryCode      String?
  normalizedCode   String?
  description      String?
  dynamicData      Json     @default("{}")
  originalText     String?  @db.Text
  indexedText      String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  folder CatalogFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@index([normalizedCode])
  @@index([dynamicData], type: Gin)
}

/// Archivo Excel respaldado en Storage.
model UploadedFile {
  id           String             @id @default(cuid())
  originalName String
  storagePath  String
  mimeType     String
  sizeBytes    Int
  status       UploadedFileStatus @default(STORED)
  uploadedById String             @db.Uuid
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  uploadedBy User        @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  importJobs ImportJob[]

  @@index([uploadedById])
  @@index([status])
  @@index([createdAt])
}

/// Operación de importación Excel hacia una carpeta.
model ImportJob {
  id              String           @id @default(cuid())
  uploadedFileId  String
  catalogId       String?
  folderId        String?
  targetSheetName String?
  status          ImportJobStatus  @default(STORED)
  actionType      ImportActionType?
  config          Json?
  resultados      Json?
  progress        Json?
  errorMessage    String?
  startedAt       DateTime         @default(now())
  finishedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  uploadedFile UploadedFile   @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  catalog      Catalog?       @relation(fields: [catalogId], references: [id], onDelete: SetNull)
  folder       CatalogFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  sheets       ImportSheet[]
  preview      ImportPreview?

  @@index([uploadedFileId])
  @@index([status])
  @@index([folderId])
  @@index([catalogId])
}

/// Hoja detectada durante el análisis de un archivo Excel.
model ImportSheet {
  id             String                    @id @default(cuid())
  importJobId    String
  sheetName      String
  classification ImportSheetClassification
  rowCount       Int                       @default(0)
  columnCount    Int                       @default(0)
  detectedHeaders Json?
  metadata       Json?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@unique([importJobId, sheetName])
  @@index([importJobId])
}

/// Vista previa de productos reconocidos antes de publicar.
model ImportPreview {
  id                 String   @id @default(cuid())
  importJobId        String   @unique
  recognizedProducts Json
  matchedProducts    Json     @default("[]")
  errors             Json     @default("[]")
  warnings           Json     @default("[]")
  summary            Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
}

/// Registro de operaciones importantes (login, CRUD, importaciones, etc.).
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @db.Uuid
  action     String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
